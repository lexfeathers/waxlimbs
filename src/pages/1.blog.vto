---
title: entries
draft: true
---
<p>Newest to oldest</p>
<div class="blog-list">
    {{ for post of search.pages("type=post", "order=desc") }}
        <p>
            <a href="{{ post.url }}" class="blog-list__post">{{ post.title |> toUpperCase() }}</a>
            <span>//</span>
            <span>{{ post.date |> date("HUMAN_DATE") |> toUpperCase() }}</span>
        </p>
    {{ /for }}
</div>
