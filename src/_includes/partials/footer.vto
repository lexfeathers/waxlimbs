<p class="footer-copy font-small">
    Made from scratch with love, by Waxlimbs ♡
</p>
<div class="footer-icons">
    {{ for item of site.socials }}
        <a href="{{ item.link }}" title="{{ item.name }}" target="_blank">
            <div class="{{ item.name }} social-icon"></div>
        </a>
    {{ /for }}
    <a href="/feed.rss" class="rss" title="RSS feed" target="_blank">
        <div class="rss social-icon"></div>
    </a>
</div>